        "typescript/prefer-includes",
        "typescript/strict-boolean-expressions",
        "typescript/switch-exhaustiveness-check",
        "typescript/unbound-method"
      ],
      "newFeatures": [
        "Type-aware rules (40 rules via oxlint-tsgolint)",
        "oxlint.config.ts support (Node v22.18+)",
        "Config extends for shared configs",
        "Vue template linting (17 rules)"
