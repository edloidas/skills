    },
    "oxfmt-0.1": {
      "highlights": [
        "Initial Oxfmt release",
        "Prettier-compatible formatting",
        "Built-in import sorting, Tailwind class sorting, package.json sorting"
      ],
      "newFeatures": [
        "printWidth defaults to 100 (vs Prettier's 80)",
        "objectWrap: preserve (Oxfmt-only)",
        "Built-in sortImports (no plugin needed)",
        "Built-in sortTailwindcss (no plugin needed)",
        "Built-in sortPackageJson (enabled by default)",
        "Built-in JSDoc formatting",
        "oxfmt --migrate=prettier for automatic migration",
        "oxfmt --migrate=biome for Biome→Oxfmt migration"
      ]
    }
